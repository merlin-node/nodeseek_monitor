# 必填: 找 @BotFather 创建 bot 获取
TG_BOT_TOKEN=1234567890:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 必填: 白名单 TG 用户 ID, 逗号分隔 (自己和朋友)
# 查自己的 ID: 给 @userinfobot 发任意消息, 或启动后给本 bot 发 /chat_id
ALLOWED_USER_IDS=123456789,987654321

# 可选: 默认推送到哪个 chat. 留空也行, 启动后给 bot 发 /open 会自动绑定
TG_CHAT_ID=

# 可选: 初始关键词/排除词 (之后用 TG 命令动态管理即可)
KEYWORDS=甲骨文,oracle,4837
EXCLUDES=求购,收购

# 轮询间隔(秒), 建议 >=60
INTERVAL=120

# 如果你的机器访问不到 api.telegram.org, 取消注释并改成你的代理
# HTTPS_PROXY=http://127.0.0.1:7890
